<Window x:Class="MenuApp.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки" Width="430" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F8F0"
        FontFamily="Segoe UI">
    <StackPanel Margin="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="38"/>
                <RowDefinition Height="38"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Бюджет (грн):" VerticalAlignment="Center" FontSize="11"/>
            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TxBudget"  VerticalAlignment="Center" FontSize="11" Padding="4,3"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Семья (чел.):" VerticalAlignment="Center" FontSize="11"/>
            <TextBox   Grid.Row="1" Grid.Column="1" x:Name="TxFamily"  Width="60" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="11" Padding="4,3"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Норма ккал/чел.:" VerticalAlignment="Center" FontSize="11"/>
            <TextBox   Grid.Row="2" Grid.Column="1" x:Name="TxCalNorm" Width="80" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="11" Padding="4,3"/>
        </Grid>

        <Separator Margin="0,8,0,6"/>
        <TextBlock Text="Распоряжение остатком бюджета:" FontWeight="Bold" FontSize="11" Margin="0,0,0,6"/>

        <CheckBox x:Name="ChkSurplus" Margin="2,3" Checked="ChkSurplus_Checked">
            <TextBlock TextWrapping="Wrap" FontSize="11">
                Остаток после нормы (≈2000 ккал/чел) — <Run FontWeight="Bold">в распоряжение пользователя</Run>.
                Меню держит норму калорий, сэкономленные деньги остаются свободными.
            </TextBlock>
        </CheckBox>

        <CheckBox x:Name="ChkFullBudget" Margin="2,3" Checked="ChkFullBudget_Checked">
            <TextBlock TextWrapping="Wrap" FontSize="11">
                Минимальный остаток — <Run FontWeight="Bold">весь бюджет на меню</Run>.
                Остаток распределяется по выходным как «праздник желудка» (красная рыба, икра).
            </TextBlock>
        </CheckBox>

        <Button Content="ОК" Width="90" Height="30" Margin="0,12,0,0"
                HorizontalAlignment="Right"
                Style="{StaticResource HdrBtn}"
                Click="BtnOk_Click"/>
    </StackPanel>
</Window>

<Window x:Class="MenuApp.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки" Width="330" Height="230"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F8F0"
        FontFamily="Segoe UI">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="130"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Бюджет (грн):" VerticalAlignment="Center" FontSize="10"/>
        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TxBudget"  VerticalAlignment="Center" FontSize="10" Padding="4,3"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Семья (чел.):" VerticalAlignment="Center" FontSize="10"/>
        <TextBox   Grid.Row="1" Grid.Column="1" x:Name="TxFamily"  Width="60" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="10" Padding="4,3"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Норма ккал/чел.:" VerticalAlignment="Center" FontSize="10"/>
        <TextBox   Grid.Row="2" Grid.Column="1" x:Name="TxCalNorm" Width="80" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="10" Padding="4,3"/>

        <Button Grid.Row="3" Grid.Column="1"
                Content="ОК" Width="80" Height="28"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Style="{StaticResource HdrBtn}"
                Click="BtnOk_Click"/>
    </Grid>
</Window>

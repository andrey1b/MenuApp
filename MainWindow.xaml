<Window x:Class="MenuApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Меню питания семьи"
        Width="1280" Height="780" MinWidth="1020" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="#D0E8D0"
        FontFamily="Segoe UI"
        FontSize="14">

    <DockPanel>

        <!-- ══════════════════════════════════════════ ШАПКА -->
        <Border DockPanel.Dock="Top" Height="130" Background="#2C5F2D">
            <Grid Margin="14,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="42"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="46"/>
                </Grid.RowDefinitions>

                <!-- Ряд 0: Заголовок · Версия · Бюджет · Дата/Ккал -->
                <DockPanel Grid.Row="0" VerticalAlignment="Center">
                    <TextBlock Text="Меню питания" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxVersion" FontSize="12" Foreground="#A8D5A9" VerticalAlignment="Bottom" Margin="6,0,28,2"/>
                    <TextBlock x:Name="TxBudget"  FontSize="13" Foreground="LightCyan" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxDayDate" FontSize="13" Foreground="White"     VerticalAlignment="Center" Margin="20,0,0,0"/>
                </DockPanel>

                <!-- Ряд 1: Уровень питания · Уведомление об обновлении -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="TxTier"   FontSize="12" Foreground="LightYellow"/>
                    <TextBlock x:Name="TxUpdate" FontSize="12" FontWeight="Bold" Foreground="Gold"
                               Margin="20,0,0,0" Visibility="Collapsed" Cursor="Hand"
                               MouseLeftButtonUp="TxUpdate_Click"/>
                </StackPanel>

                <!-- Ряд 2: Период · Быстрые кнопки · Поиск · Настройки
                     ВАЖНО: правые кнопки объявляются ПЕРВЫМИ — иначе DockPanel их обрезает -->
                <DockPanel Grid.Row="2" VerticalAlignment="Center">

                    <!-- Правая сторона — объявляем первыми! -->
                    <Button x:Name="BtnSettings" Content="Настройки"
                            Style="{StaticResource HdrBtn}" Width="120"
                            DockPanel.Dock="Right" Margin="5,0,0,0" Click="BtnSettings_Click"/>
                    <Button x:Name="BtnYT" Content="YouTube" IsEnabled="False"
                            Style="{StaticResource HdrBtn}" Width="100"
                            DockPanel.Dock="Right" Margin="5,0,0,0" Click="BtnYT_Click"/>
                    <Button x:Name="BtnBing" Content="Bing" IsEnabled="False"
                            Style="{StaticResource HdrBtn}" Width="78"
                            DockPanel.Dock="Right" Margin="5,0,0,0" Click="BtnBing_Click"/>
                    <Button x:Name="BtnGoogle" Content="Google" IsEnabled="False"
                            Style="{StaticResource HdrBtn}" Width="92"
                            DockPanel.Dock="Right" Margin="5,0,0,0" Click="BtnGoogle_Click"/>

                    <!-- Левая сторона -->
                    <DatePicker x:Name="DtpStart" Width="128" Margin="0,0,5,0"
                                SelectedDateFormat="Short"
                                SelectedDateChanged="DtpPeriod_Changed"/>
                    <DatePicker x:Name="DtpEnd"   Width="128" Margin="0,0,5,0"
                                SelectedDateFormat="Short"
                                SelectedDateChanged="DtpPeriod_Changed"/>
                    <Button x:Name="BtnApply" Content="▶ Применить"
                            Style="{StaticResource HdrBtn}" Width="148" Margin="0,0,6,0"
                            Click="BtnApply_Click"/>
                    <Button x:Name="Btn7d"  Content="7 дн."  Style="{StaticResource HdrBtn}" Width="78" Margin="0,0,5,0" Click="Btn7d_Click"/>
                    <Button x:Name="Btn30d" Content="30 дн." Style="{StaticResource HdrBtn}" Width="88" Margin="0,0,5,0" Click="Btn30d_Click"/>
                    <!-- Заполняет остаток — предупреждение о периоде -->
                    <TextBlock x:Name="TxPeriodWarn" FontSize="12" FontStyle="Italic"
                               Foreground="LightSalmon" VerticalAlignment="Center" Margin="6,0,0,0"/>
                </DockPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════ ВКЛАДКИ -->
        <TabControl Background="Transparent">

            <!-- Вкладка 0: Сегодня (полностью WPF) -->
            <TabItem Header="  Сегодня  ">
                <DockPanel>
                    <Grid x:Name="CardsGrid" DockPanel.Dock="Top" Height="140" Background="#D0E8D0"/>
                    <Grid>
                        <wv2:WebView2 x:Name="WebBrowser"/>
                        <TextBlock x:Name="TxWebError" Visibility="Collapsed"
                                   TextAlignment="Center" VerticalAlignment="Center"
                                   FontSize="14" Foreground="Gray"
                                   TextWrapping="Wrap" Padding="20"/>
                    </Grid>
                </DockPanel>
            </TabItem>

            <TabItem Header="  Меню  ">
                <DockPanel>
                    <Border DockPanel.Dock="Bottom" Background="White" BorderBrush="#A0A0A0" BorderThickness="0,1,0,0" MinHeight="34">
                        <TextBlock x:Name="lblMenuBudget" VerticalAlignment="Center" Margin="4,4,4,4"
                                   FontWeight="Bold" FontSize="12" TextWrapping="Wrap"/>
                    </Border>
                    <DataGrid x:Name="dgMenu" Style="{StaticResource GridBase}"
                          HorizontalScrollBarVisibility="Auto">
                    <DataGrid.Resources>
                        <!-- Текст ячеек с блюдами: перенос по словам, фон = подсветка «неизвестное блюдо» -->
                        <Style x:Key="MealText" TargetType="TextBlock">
                            <Setter Property="TextWrapping"        Value="Wrap"/>
                            <Setter Property="VerticalAlignment"   Value="Center"/>
                            <Setter Property="Margin"              Value="5,2,5,2"/>
                        </Style>
                        <!-- Числовые ккал-ячейки: справа, серым -->
                        <Style x:Key="CalText" TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="VerticalAlignment"   Value="Center"/>
                            <Setter Property="Foreground"          Value="DimGray"/>
                            <Setter Property="Margin"              Value="0,0,6,0"/>
                        </Style>
                        <!-- Числовые ценовые ячейки: справа, зелёным -->
                        <Style x:Key="PriceText" TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="VerticalAlignment"   Value="Center"/>
                            <Setter Property="Foreground"          Value="#2E7D32"/>
                            <Setter Property="Margin"              Value="0,0,6,0"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="День" Binding="{Binding Date}" Width="116">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                    <Setter Property="Background" Value="{Binding DateBg}"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin"            Value="6,0,0,0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsToday}" Value="True">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="#1B5E20"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- ── Завтрак: Блюдо | Цена | Ккал ── -->
                        <DataGridTextColumn Header="Завтрак" Binding="{Binding Breakfast}" Width="150" ElementStyle="{StaticResource MealText}">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                    <Setter Property="Background" Value="{Binding BreakfastBg}"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Цена" Binding="{Binding PriceBf}" Width="70" ElementStyle="{StaticResource PriceText}">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                    <Setter Property="Background" Value="{Binding BfGroup}"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Ккал" Binding="{Binding CalBf}" Width="70" ElementStyle="{StaticResource CalText}">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                    <Setter Property="Background" Value="{Binding BfGroup}"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>

                        <!-- ── Обед: Блюдо | Цена | Ккал ── -->
                        <DataGridTextColumn Header="Обед" Binding="{Binding Lunch}" Width="160" ElementStyle="{StaticResource MealText}">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                    <Setter Property="Background" Value="{Binding LunchBg}"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Цена" Binding="{Binding PriceLn}" Width="70" ElementStyle="{StaticResource PriceText}">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                    <Setter Property="Background" Value="{Binding LnGroup}"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Ккал" Binding="{Binding CalLn}" Width="70" ElementStyle="{StaticResource CalText}">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                    <Setter Property="Background" Value="{Binding LnGroup}"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>

                        <!-- ── Полдник: Блюдо | Цена | Ккал ── -->
                        <DataGridTextColumn Header="Полдник" Binding="{Binding Snack}" Width="110" ElementStyle="{StaticResource MealText}">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                    <Setter Property="Background" Value="{Binding SnackBg}"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Цена" Binding="{Binding PriceSn}" Width="70" ElementStyle="{StaticResource PriceText}">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                    <Setter Property="Background" Value="{Binding SnGroup}"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Ккал" Binding="{Binding CalSn}" Width="70" ElementStyle="{StaticResource CalText}">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                    <Setter Property="Background" Value="{Binding SnGroup}"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>

                        <!-- ── Ужин: Блюдо | Цена | Ккал ── -->
                        <DataGridTextColumn Header="Ужин" Binding="{Binding Dinner}" Width="150" ElementStyle="{StaticResource MealText}">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                    <Setter Property="Background" Value="{Binding DinnerBg}"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Цена" Binding="{Binding PriceDn}" Width="70" ElementStyle="{StaticResource PriceText}">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                    <Setter Property="Background" Value="{Binding DnGroup}"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Ккал" Binding="{Binding CalDn}" Width="70" ElementStyle="{StaticResource CalText}">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                    <Setter Property="Background" Value="{Binding DnGroup}"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Ккал/день" Binding="{Binding CalDay}" Width="86">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment"   Value="Center"/>
                                    <Setter Property="FontWeight"          Value="Bold"/>
                                    <Setter Property="Foreground"          Value="{Binding CalDayBrush}"/>
                                    <Setter Property="Margin"              Value="0,0,6,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Норма ккал" Binding="{Binding CalNorm}" Width="85">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment"   Value="Center"/>
                                    <Setter Property="Foreground"          Value="{Binding CalNormBrush}"/>
                                    <Setter Property="Margin"              Value="0,0,6,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="~Стоим. грн" Binding="{Binding DayCost}" Width="90">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment"   Value="Center"/>
                                    <Setter Property="Foreground"          Value="{Binding DayCostBrush}"/>
                                    <Setter Property="Margin"              Value="0,0,6,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
            <TabItem Header="  Продукты  ">
                <DockPanel>
                    <Border DockPanel.Dock="Bottom" Background="White" BorderBrush="#A0A0A0" BorderThickness="0,1,0,0" Height="34">
                        <TextBlock x:Name="lblBudgetStatus" HorizontalAlignment="Right" VerticalAlignment="Center"
                                   Margin="0,0,12,0" FontWeight="Bold" FontSize="12"/>
                    </Border>
                    <DataGrid x:Name="dgProducts" Style="{StaticResource GridBase}" IsReadOnly="False"
                              RowStyle="{StaticResource ProductRowStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Продукт" Width="26*" Binding="{Binding ProductName}" ElementStyle="{StaticResource CellLeft}"/>
                            <DataGridTextColumn Header="Уровень" Width="8*" IsReadOnly="True" Binding="{Binding Tier}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment"   Value="Center"/>
                                        <Setter Property="FontWeight"          Value="Bold"/>
                                        <Setter Property="FontSize"            Value="12"/>
                                        <Setter Property="Foreground"          Value="{Binding TierBrush}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridComboBoxColumn x:Name="colFreq" Header="Частота" Width="13*" SelectedItemBinding="{Binding Frequency}">
                                <DataGridComboBoxColumn.ElementStyle>
                                    <Style TargetType="ComboBox">
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTotal}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridComboBoxColumn.ElementStyle>
                            </DataGridComboBoxColumn>
                            <DataGridTextColumn Header="Ед."        Width="6*"  Binding="{Binding Unit}"  ElementStyle="{StaticResource CellCenter}"/>
                            <DataGridTextColumn Header="Цена (грн)" Width="9*"  Binding="{Binding Price}" ElementStyle="{StaticResource CellRight}"/>
                            <DataGridTextColumn Header="Реал. цена" Width="9*" IsReadOnly="True" Binding="{Binding RealPrice}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CellRight}">
                                        <Setter Property="Foreground" Value="{Binding RealPriceBrush}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Кол-во" Width="7*" Binding="{Binding Qty}" ElementStyle="{StaticResource CellRight}"/>
                            <DataGridTextColumn Header="Упаковок" Width="11*" IsReadOnly="True" Binding="{Binding PackInfo}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CellCenter}">
                                        <Setter Property="Foreground" Value="MidnightBlue"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Сумма (грн)" Width="10*" IsReadOnly="True" Binding="{Binding Sum}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CellRight}">
                                        <Setter Property="Foreground" Value="DarkGreen"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTotal}" Value="True">
                                                <Setter Property="Foreground" Value="#82E682"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Ккал/пер." Width="9*" IsReadOnly="True" Binding="{Binding Kcal}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CellRight}">
                                        <Setter Property="Foreground" Value="DarkBlue"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTotal}" Value="True">
                                                <Setter Property="Foreground" Value="#B4DCFF"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
            <TabItem Header="  Покупки  ">
                <Grid Background="WhiteSmoke">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <!-- Сегодня -->
                    <DockPanel Grid.Column="0" Margin="4">
                        <Border DockPanel.Dock="Top" Background="#FFFBD6" Height="52">
                            <Grid>
                                <TextBlock x:Name="lblTodayTitle" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="14" FontWeight="Bold" Foreground="DarkSlateGray"/>
                                <Button x:Name="btnCopyToday" Content="📋" Width="30" Height="30" FontSize="14"
                                        HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Скопировать список"/>
                            </Grid>
                        </Border>
                        <DataGrid x:Name="dgShopToday" Style="{StaticResource GridBase}" IsReadOnly="False">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="✓" Width="44">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding Done, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ShopDoneBox}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Продукт"     Width="2.2*" IsReadOnly="True" Binding="{Binding Product}"  ElementStyle="{StaticResource ShopText}"/>
                                <DataGridTextColumn Header="Количество"  Width="1.3*" IsReadOnly="True" Binding="{Binding Quantity}" ElementStyle="{StaticResource ShopTextCenter}"/>
                                <DataGridTextColumn Header="~Цена (грн)" Width="1*"   IsReadOnly="True" Binding="{Binding Price}"    ElementStyle="{StaticResource ShopPriceText}"/>
                                <DataGridTextColumn Header="Заплачено"   Width="1*"   Binding="{Binding Paid, UpdateSourceTrigger=LostFocus}" ElementStyle="{StaticResource ShopPaidText}" CellStyle="{StaticResource ShopPaidCell}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                    <!-- Завтра -->
                    <DockPanel Grid.Column="1" Margin="4">
                        <Border DockPanel.Dock="Top" Background="#D6F1D6" Height="52">
                            <Grid>
                                <TextBlock x:Name="lblTomorrowTitle" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="14" FontWeight="Bold" Foreground="DarkSlateGray"/>
                                <Button x:Name="btnCopyTomorrow" Content="📋" Width="30" Height="30" FontSize="14"
                                        HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Скопировать список"/>
                            </Grid>
                        </Border>
                        <DataGrid x:Name="dgShopTomorrow" Style="{StaticResource GridBase}" IsReadOnly="False">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="✓" Width="44">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding Done, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ShopDoneBox}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Продукт"     Width="2.2*" IsReadOnly="True" Binding="{Binding Product}"  ElementStyle="{StaticResource ShopText}"/>
                                <DataGridTextColumn Header="Количество"  Width="1.3*" IsReadOnly="True" Binding="{Binding Quantity}" ElementStyle="{StaticResource ShopTextCenter}"/>
                                <DataGridTextColumn Header="~Цена (грн)" Width="1*"   IsReadOnly="True" Binding="{Binding Price}"    ElementStyle="{StaticResource ShopPriceText}"/>
                                <DataGridTextColumn Header="Заплачено"   Width="1*"   Binding="{Binding Paid, UpdateSourceTrigger=LostFocus}" ElementStyle="{StaticResource ShopPaidText}" CellStyle="{StaticResource ShopPaidCell}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Grid>
            </TabItem>
            <TabItem Header="  Покупки на неделю  ">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#C8E4C8" Height="50">
                        <Grid>
                            <TextBlock x:Name="lblWeeklyTitle" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="14" FontWeight="Bold" Foreground="DarkSlateGray"/>
                            <Button x:Name="btnCopyWeekly" Content="📋" Width="30" Height="30" FontSize="14"
                                    HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Скопировать список"/>
                        </Grid>
                    </Border>
                    <Border DockPanel.Dock="Bottom" Background="#D2ECD2" Height="42" BorderBrush="#9DBF9D" BorderThickness="1">
                        <TextBlock x:Name="lblWeeklyInfo" HorizontalAlignment="Right" VerticalAlignment="Center"
                                   Margin="0,0,12,0" FontSize="14" FontWeight="Bold"/>
                    </Border>
                    <DataGrid x:Name="dgShopWeekly" Style="{StaticResource GridBase}" IsReadOnly="False">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="✓" Width="44">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding Done, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ShopDoneBox}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Продукт"     Width="2.2*" IsReadOnly="True" Binding="{Binding Product}"  ElementStyle="{StaticResource ShopText}"/>
                            <DataGridTextColumn Header="Количество"  Width="1.3*" IsReadOnly="True" Binding="{Binding Quantity}" ElementStyle="{StaticResource ShopTextCenter}"/>
                            <DataGridTextColumn Header="~Цена (грн)" Width="1*"   IsReadOnly="True" Binding="{Binding Price}"    ElementStyle="{StaticResource ShopPriceText}"/>
                            <DataGridTextColumn Header="Заплачено"   Width="1*"   Binding="{Binding Paid, UpdateSourceTrigger=LostFocus}" ElementStyle="{StaticResource ShopPaidText}" CellStyle="{StaticResource ShopPaidCell}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
            <TabItem Header="  Покупки на месяц  ">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#D6F5E1" Height="50">
                        <Grid>
                            <TextBlock x:Name="lblMonthlyTitle" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="14" FontWeight="Bold" Foreground="DarkSlateGray"/>
                            <Button x:Name="btnCopyMonthly" Content="📋" Width="30" Height="30" FontSize="14"
                                    HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Скопировать список"/>
                        </Grid>
                    </Border>
                    <Border DockPanel.Dock="Bottom" Background="#DCFFEB" Height="42" BorderBrush="#9DBF9D" BorderThickness="1">
                        <TextBlock x:Name="lblMonthlyInfo" HorizontalAlignment="Right" VerticalAlignment="Center"
                                   Margin="0,0,12,0" FontSize="14" FontWeight="Bold"/>
                    </Border>
                    <DataGrid x:Name="dgShopMonthly" Style="{StaticResource GridBase}" IsReadOnly="False">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="✓" Width="44">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding Done, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ShopDoneBox}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Продукт"     Width="2.2*" IsReadOnly="True" Binding="{Binding Product}"  ElementStyle="{StaticResource ShopText}"/>
                            <DataGridTextColumn Header="Количество"  Width="1.3*" IsReadOnly="True" Binding="{Binding Quantity}" ElementStyle="{StaticResource ShopTextCenter}"/>
                            <DataGridTextColumn Header="~Цена (грн)" Width="1*"   IsReadOnly="True" Binding="{Binding Price}"    ElementStyle="{StaticResource ShopPriceText}"/>
                            <DataGridTextColumn Header="Заплачено"   Width="1*"   Binding="{Binding Paid, UpdateSourceTrigger=LostFocus}" ElementStyle="{StaticResource ShopPaidText}" CellStyle="{StaticResource ShopPaidCell}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
            <TabItem Header="  Реальные цены  ">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#E4F4E4" Height="42" Padding="6,6,6,0">
                        <Grid>
                            <TextBlock x:Name="lblRealFile" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="12" Foreground="DimGray"/>
                            <Button x:Name="btnRealRefresh" Content="⟳ Обновить из файла" HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Margin="0,0,12,0" Height="30" Width="180" Background="#3E8741" Foreground="White"
                                    BorderThickness="0" FontWeight="Bold" Cursor="Hand"/>
                        </Grid>
                    </Border>
                    <Border DockPanel.Dock="Bottom" Background="#E4F2E4" BorderBrush="#9DBF9D" BorderThickness="1" Height="40">
                        <TextBlock x:Name="lblRealStatus" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="12" Foreground="DimGray"/>
                    </Border>
                    <DataGrid x:Name="dgRealPrices" Style="{StaticResource GridBase}" IsReadOnly="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Наш продукт" Width="20*" IsReadOnly="True" Binding="{Binding RpApp}" ElementStyle="{StaticResource CellLeft}"/>
                            <DataGridTextColumn Header="Ед." Width="4*" IsReadOnly="True" Binding="{Binding RpUnit}" ElementStyle="{StaticResource CellCenter}"/>
                            <DataGridComboBoxColumn x:Name="colRpExcel" Header="Название в расходах" Width="20*" SelectedItemBinding="{Binding RpExcel}"/>
                            <DataGridTextColumn Header="Ед. Excel" Width="5*" IsReadOnly="True" Binding="{Binding RpExUnit}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CellCenter}">
                                        <Setter Property="Foreground" Value="DimGray"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Коэф." Width="5*" Binding="{Binding RpMult}" ElementStyle="{StaticResource CellCenter}"/>
                            <DataGridTextColumn Header="Посл. цена" Width="10*" IsReadOnly="True" Binding="{Binding RpLast}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CellRight}">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="{Binding LastBrush}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                                <DataGridTextColumn.CellStyle>
                                    <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                        <Setter Property="Background" Value="#F0FFF0"/>
                                    </Style>
                                </DataGridTextColumn.CellStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Ср. 30 дн." Width="10*" IsReadOnly="True" Binding="{Binding RpAvg30}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CellRight}">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Ср. 90 дн." Width="10*" IsReadOnly="True" Binding="{Binding RpAvg90}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CellRight}">
                                        <Setter Property="Foreground" Value="DimGray"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Наша цена" Width="9*" IsReadOnly="True" Binding="{Binding RpOur}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CellRight}">
                                        <Setter Property="Foreground" Value="DimGray"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Разница" Width="7*" IsReadOnly="True" Binding="{Binding RpDiff}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CellCenter}">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="{Binding DiffBrush}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
            <TabItem Header="  Составить список  ">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Левая часть: кнопки + таблица -->
                    <DockPanel Grid.Column="0">
                        <Border DockPanel.Dock="Top" Background="WhiteSmoke" Padding="8,8,8,4">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="btnSlAll"     Content="Выбрать все" Height="34" Padding="12,0" Margin="0,0,8,0"
                                            Background="#C3E6C3" BorderBrush="#9DBF9D" BorderThickness="1" Cursor="Hand"/>
                                    <Button x:Name="btnSlNone"    Content="Снять все"   Height="34" Padding="12,0" Margin="0,0,8,0"
                                            Background="#E6C8C8" BorderBrush="#BF9D9D" BorderThickness="1" Cursor="Hand"/>
                                    <Button x:Name="btnSlRefresh" Content="🔄 Обновить" Height="34" Padding="12,0" Margin="0,0,12,0"
                                            Background="#D2E6FF" BorderBrush="#9DB3BF" BorderThickness="1" Cursor="Hand"/>
                                    <TextBlock Text="Отметьте продукты, укажите количество, затем «Открыть на телефоне» →"
                                               VerticalAlignment="Center" FontSize="12" Foreground="DimGray" TextWrapping="Wrap"/>
                                </StackPanel>
                                <TextBlock x:Name="lblListSource" Margin="2,6,0,0" FontSize="12" Foreground="#508050"/>
                            </StackPanel>
                        </Border>
                        <DataGrid x:Name="dgShopList" Style="{StaticResource GridBase}" IsReadOnly="False">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="✓" Width="44">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding Check, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Продукт"    Width="5*"   IsReadOnly="True" Binding="{Binding Name}" ElementStyle="{StaticResource CellLeft}"/>
                                <DataGridTextColumn Header="Количество" Width="2.6*" Binding="{Binding Qty, UpdateSourceTrigger=LostFocus}" ElementStyle="{StaticResource CellLeft}"/>
                                <DataGridTextColumn Header="Ед."        Width="1.7*" IsReadOnly="True" Binding="{Binding Unit}" ElementStyle="{StaticResource CellCenter}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>

                    <!-- Правая часть: сервер + QR -->
                    <Border Grid.Column="1" Background="#EEF8EE" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Отправить на телефон" FontSize="15" FontWeight="Bold" Foreground="#2C5F2D" Margin="0,0,0,12"/>
                            <Button x:Name="btnStartServer" Content="📱  Открыть на телефоне" Height="46" FontSize="13" FontWeight="Bold"
                                    Background="#2C5F2D" Foreground="White" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Left" Width="270"/>
                            <Button x:Name="btnStopServer" Content="■  Остановить сервер" Height="46" FontSize="13" FontWeight="Bold"
                                    Background="#BE3232" Foreground="White" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Left" Width="270"
                                    Visibility="Collapsed" Margin="0,0,0,0"/>
                            <TextBlock x:Name="lblScanHint" Margin="0,16,0,0" FontSize="12" Foreground="DimGray" TextWrapping="Wrap"
                                       Text="Отсканируйте QR-код или откройте адрес в браузере телефона:" Visibility="Collapsed"/>
                            <TextBlock x:Name="lblServerUrl" Margin="0,10,0,0" FontFamily="Courier New" FontSize="14" FontWeight="Bold"
                                       Foreground="#004696" Visibility="Collapsed"/>
                            <Border x:Name="qrBorder" Margin="0,12,0,0" Width="250" Height="250" Background="White"
                                    BorderBrush="#A0A0A0" BorderThickness="1" HorizontalAlignment="Left" Visibility="Collapsed">
                                <Image x:Name="imgQr" Stretch="Uniform"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
            <TabItem Header="  Расходы (Деньги)  ">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#EEF8EE" Padding="10,8">
                        <DockPanel LastChildFill="True">
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                                <Button x:Name="btnFoodRefresh" Style="{StaticResource RoundBtn}"
                                        Content="🔄 Обновить" Background="#DADEF0" Foreground="#28326E"
                                        Margin="4,0,0,0" Click="BtnFoodRefresh_Click"/>
                                <Button x:Name="btnFoodOpenMoney" Style="{StaticResource RoundBtn}"
                                        Content="Открыть «Деньги»" Background="#2C5F2D" Foreground="White"
                                        Margin="4,0,0,0" Click="BtnFoodOpenMoney_Click"/>
                            </StackPanel>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="lblFoodTotal" FontSize="15" FontWeight="Bold" Foreground="#1E461E"/>
                                <TextBlock Text="Расходы на продукты ведутся в «Деньгах» (категория «Продукты питания»). Здесь — только просмотр; меню и списки покупок — это план."
                                           FontSize="11" Foreground="#5A7A5A" TextWrapping="Wrap"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <TextBlock x:Name="lblFoodInfo" DockPanel.Dock="Bottom" Margin="10,4" FontSize="11" Foreground="DimGray"/>
                    <DataGrid x:Name="dgFoodExpenses" AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" CanUserAddRows="False" GridLinesVisibility="Horizontal"
                              Background="#F5FAF5" RowBackground="White" Margin="6" FontSize="13">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Дата" Binding="{Binding DateText}" Width="110"/>
                            <DataGridTextColumn Header="Продукт / статья" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Счёт" Binding="{Binding Account}" Width="160"/>
                            <DataGridTextColumn Header="Сумма, грн" Binding="{Binding AmountText}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
            <TabItem Header="  Вопросы ИИ  ">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#EEF8EE" Padding="10,8">
                        <StackPanel>
                            <DockPanel LastChildFill="True">
                                <TextBlock Text="Вопрос:" DockPanel.Dock="Left" VerticalAlignment="Center" FontSize="14" Margin="2,0,8,0"/>
                                <Button x:Name="btnAiApiKeys" DockPanel.Dock="Right" Style="{StaticResource RoundBtn}"
                                        Content="⚙  API ключи" Background="#DADEF0" Foreground="#28326E" Margin="4,0,0,0"/>
                                <Button x:Name="btnAiSaveAll" DockPanel.Dock="Right" Style="{StaticResource RoundBtn}"
                                        Content="Сохранить все" Background="#C3E4C3" Foreground="#1E461E" Margin="4,0,0,0"/>
                                <Button x:Name="btnAiAsk" DockPanel.Dock="Right" Style="{StaticResource RoundBtn}"
                                        Content="▶  Спросить" Background="#2C5F2D" Margin="4,0,0,0"/>
                                <TextBox x:Name="txAiQuestion" FontSize="14" Height="32" VerticalContentAlignment="Center" Margin="0,0,8,0"/>
                            </DockPanel>
                            <TextBlock x:Name="lblAiStatus" Margin="2,5,0,0" FontSize="11" Foreground="DimGray"/>
                        </StackPanel>
                    </Border>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#F5FAF5">
                        <ItemsControl x:Name="icAiRows">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="190" Margin="6,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="15*"/>
                                            <ColumnDefinition Width="70*"/>
                                            <ColumnDefinition Width="15*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Style="{StaticResource RoundBtn}" FontSize="15" Margin="5"
                                                Content="{Binding Name}" Background="{Binding HeaderBrush}"
                                                Click="AiOpenButton_Click"/>
                                        <TextBox Grid.Column="1" Margin="3,5" Text="{Binding Response, UpdateSourceTrigger=PropertyChanged}"
                                                 Foreground="{Binding ResponseBrush}" AcceptsReturn="True" TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto" FontSize="12"/>
                                        <StackPanel Grid.Column="2" Margin="3,5,5,5">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="30" Height="30" CornerRadius="6" BorderBrush="#2C5F2D" BorderThickness="2"
                                                        Background="White" VerticalAlignment="Top" Margin="2,2,6,0">
                                                    <CheckBox IsChecked="{Binding Enabled}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <Button Style="{StaticResource RoundBtn}" Content="Сохранить" FontSize="11"
                                                        Background="#C8E4C8" Foreground="#1E461E" VerticalAlignment="Top" Margin="0,2,0,0"
                                                        Click="AiSaveButton_Click"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Stats}" Margin="6,6,0,0" FontSize="11" Foreground="#5A5A5A"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

        </TabControl>

    </DockPanel>
</Window>

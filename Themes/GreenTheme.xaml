<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Кнопка шапки/карточек -->
    <Style x:Key="HdrBtn" TargetType="Button">
        <Setter Property="Background"        Value="#3E8741"/>
        <Setter Property="Foreground"        Value="White"/>
        <Setter Property="FontFamily"        Value="Segoe UI"/>
        <Setter Property="FontSize"          Value="15"/>
        <Setter Property="FontWeight"        Value="Bold"/>
        <Setter Property="Height"            Value="38"/>
        <Setter Property="BorderThickness"   Value="0"/>
        <Setter Property="Cursor"            Value="Hand"/>
        <Setter Property="FocusVisualStyle"  Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="6" Padding="10,0">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#4CA04F"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#2C5F2D"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Background" Value="#A0A0A0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Стиль вкладок -->
    <Style TargetType="TabControl">
        <Setter Property="Background"      Value="#D0E8D0"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="0"/>
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="Bd" Background="#C8DEC8" Margin="1,0" Padding="10,0">
                        <TextBlock x:Name="Txt" Text="{TemplateBinding Header}"
                                   FontFamily="Segoe UI" FontSize="15"
                                   Foreground="#2C5F2D" FontWeight="Normal"
                                   VerticalAlignment="Center" Height="44"
                                   TextAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd"  Property="Background"  Value="#2C5F2D"/>
                            <Setter TargetName="Txt" Property="Foreground"  Value="White"/>
                            <Setter TargetName="Txt" Property="FontWeight"  Value="Bold"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsSelected"  Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="#A8C8A8"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════ Общие стили таблиц (DataGrid) для миграции на WPF ═══════════════ -->

    <!-- Заголовок колонки: тёмно-зелёный фон, белый жирный текст, по центру -->
    <Style x:Key="GridHeader" TargetType="DataGridColumnHeader">
        <Setter Property="Background"           Value="#2C5F2D"/>
        <Setter Property="Foreground"           Value="White"/>
        <Setter Property="FontWeight"           Value="Bold"/>
        <Setter Property="FontSize"             Value="13"/>
        <Setter Property="Height"               Value="42"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment"   Value="Center"/>
        <Setter Property="BorderBrush"          Value="#1E3A1E"/>
        <Setter Property="BorderThickness"      Value="0,0,1,0"/>
        <Setter Property="SeparatorBrush"       Value="#1E3A1E"/>
    </Style>

    <!-- Строка таблицы: чередование (AliceBlue) + особая строка ИТОГО (тёмная, белый жирный) -->
    <Style x:Key="GridRow" TargetType="DataGridRow">
        <Setter Property="Background" Value="White"/>
        <Style.Triggers>
            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                <Setter Property="Background" Value="AliceBlue"/>
            </Trigger>
            <DataTrigger Binding="{Binding IsTotal}" Value="True">
                <Setter Property="Background" Value="#1E3A1E"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontWeight" Value="Bold"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Базовая таблица: read-only, без сортировки/добавления, зелёные линии сетки -->
    <Style x:Key="GridBase" TargetType="DataGrid">
        <Setter Property="AutoGenerateColumns"      Value="False"/>
        <Setter Property="IsReadOnly"               Value="True"/>
        <Setter Property="HeadersVisibility"        Value="Column"/>
        <Setter Property="SelectionMode"            Value="Single"/>
        <Setter Property="SelectionUnit"            Value="FullRow"/>
        <Setter Property="CanUserAddRows"           Value="False"/>
        <Setter Property="CanUserDeleteRows"        Value="False"/>
        <Setter Property="CanUserResizeRows"        Value="False"/>
        <Setter Property="CanUserSortColumns"       Value="False"/>
        <Setter Property="CanUserReorderColumns"    Value="False"/>
        <Setter Property="GridLinesVisibility"      Value="All"/>
        <Setter Property="HorizontalGridLinesBrush" Value="#A8D5A9"/>
        <Setter Property="VerticalGridLinesBrush"   Value="#A8D5A9"/>
        <Setter Property="Background"               Value="White"/>
        <Setter Property="RowBackground"            Value="White"/>
        <Setter Property="BorderThickness"          Value="0"/>
        <Setter Property="FontFamily"               Value="Segoe UI"/>
        <Setter Property="FontSize"                 Value="13"/>
        <Setter Property="MinRowHeight"             Value="40"/>
        <Setter Property="AlternationCount"         Value="2"/>
        <Setter Property="ColumnHeaderStyle"        Value="{StaticResource GridHeader}"/>
        <Setter Property="RowStyle"                 Value="{StaticResource GridRow}"/>
    </Style>

    <!-- ═══════════════ Стили ячеек списка покупок ═══════════════ -->
    <!-- Текст: серый + зачёркнутый, когда позиция отмечена «куплено» (Done) -->
    <Style x:Key="ShopText" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin"            Value="6,0,6,0"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding Done}" Value="True">
                <Setter Property="Foreground"      Value="Gray"/>
                <Setter Property="TextDecorations" Value="Strikethrough"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>
    <Style x:Key="ShopTextCenter" TargetType="TextBlock" BasedOn="{StaticResource ShopText}">
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>
    <!-- Цена: справа; в строке ИТОГО — серая -->
    <Style x:Key="ShopPriceText" TargetType="TextBlock" BasedOn="{StaticResource ShopText}">
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsTotal}" Value="True">
                <Setter Property="Foreground" Value="#A0A0A0"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>
    <!-- Заплачено: справа; в строке ИТОГО — светло-зелёная сумма -->
    <Style x:Key="ShopPaidText" TargetType="TextBlock" BasedOn="{StaticResource ShopText}">
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsTotal}" Value="True">
                <Setter Property="Foreground" Value="#82E682"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>
    <!-- Ячейка «Заплачено»: светло-жёлтый фон; в строке ИТОГО — прозрачный (виден тёмный фон строки) -->
    <Style x:Key="ShopPaidCell" TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
        <Setter Property="Background" Value="#FFFFE6"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsTotal}" Value="True">
                <Setter Property="Background" Value="Transparent"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>
    <!-- Чекбокс «куплено»: по центру; скрыт в строке ИТОГО -->
    <Style x:Key="ShopDoneBox" TargetType="CheckBox">
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment"   Value="Center"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsTotal}" Value="True">
                <Setter Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
